# Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI API Key (required for AI responses)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Google Gemini API Key (for alternative AI service)
# Get it from: https://makersuite.google.com/
GEMINI_API_KEY=AIzaSyC-your-gemini-api-key-here

# Optional: Multiple Gemini keys for automatic rotation
GEMINI_API_KEYS=AIzaSy-key1,AIzaSy-key2,AIzaSy-key3

# Gemini settings
GEMINI_ROTATE_AFTER_REQUESTS=5
GEMINI_SUMMARIZE_LARGE=True
GEMINI_MAX_CHUNKS=14
GEMINI_MIN_CHUNK_CHARS=25000
GEMINI_MAX_CHUNK_CHARS=220000
GEMINI_SUMMARY_CACHE_MAX=64
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_DELAY=3
GEMINI_MAX_OUTPUT_TOKENS=6000
GEMINI_LEARN_MAX_OUTPUT_TOKENS=4000
GEMINI_LEARN_TARGET_CHARS=25000
GEMINI_LEARN_HISTORY_TARGET_CHARS=32000

# Rate limiting and caching
AI_RATE_LIMIT_ENABLED=True
AI_RATE_LIMIT_PER_WINDOW=3
AI_RATE_LIMIT_WINDOW_SECONDS=3600
AI_CACHE_TTL_SECONDS=3600
AI_CACHE_MAX=64

# Server configuration
AI_TEACHER_PORT=5000
FLASK_DEBUG=False
