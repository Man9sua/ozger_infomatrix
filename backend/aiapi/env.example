OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4
OPENAI_MODEL_FALLBACKS=gpt-4o
OPENAI_TIMEOUT_SECONDS=30
OPENAI_SDK_MAX_RETRIES=2

GEMINI_API_KEY=your-gemini-api-key
# Optional comma-separated keys for rotation
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MODEL_CHAIN=
GEMINI_ROTATE_AFTER_REQUESTS=20
GEMINI_ROTATE_HOURS=1
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_DELAY=3
GEMINI_SUMMARIZE_LARGE=false
GEMINI_MAX_CHUNKS=8
GEMINI_MIN_CHUNK_CHARS=30000
GEMINI_MAX_CHUNK_CHARS=200000
GEMINI_SUMMARY_CACHE_MAX=32
GEMINI_MAX_OUTPUT_TOKENS=6000
GEMINI_LEARN_MAX_OUTPUT_TOKENS=4000
GEMINI_LEARN_TARGET_CHARS=25000
GEMINI_LEARN_HISTORY_TARGET_CHARS=32000
GEMINI_QUIZ_TIMEOUT_SECONDS=20
GEMINI_PRACTICE_MAX_OUTPUT_TOKENS=5200
GEMINI_REALTEST_MAX_OUTPUT_TOKENS=4200

SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

AI_TEACHER_PORT=5000
FLASK_PORT=5000
FLASK_DEBUG=false
AI_MATERIALS_DIR=/tmp/ai_materials
ASSISTANT_FAST_MODE=true
